#!/usr/bin/env bash
set -euo pipefail

SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_SOURCE" ]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"
  SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
  case "$SCRIPT_SOURCE" in
    /*) ;;
    *) SCRIPT_SOURCE="$SCRIPT_DIR/$SCRIPT_SOURCE" ;;
  esac
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"
. "$SCRIPT_DIR/dev-editor-config.sh"

GHOSTTY_APP="${GHOSTTY_APP:-$(editor_bridge_string_or_default "launcher.ghosttyApp" "Ghostty.app")}"
GHOSTTY_HELPER="${DEV_EDITOR_GHOSTTY_HELPER:-$HOME/.local/bin/dev-editor-ghostty}"

if [ ! -x "$GHOSTTY_HELPER" ]; then
  echo "dev-editor-open: missing helper at $GHOSTTY_HELPER" >&2
  exit 1
fi

exec open -na "$GHOSTTY_APP" --args -e "$GHOSTTY_HELPER" --stay-attached --cwd "$PWD" -- "$@"
